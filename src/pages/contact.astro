---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { site } from '../data/site';
---
<BaseLayout title="Contact WB Built | Discuss Your Project">
  <Hero overlay={true} />

  <!-- Contact intro -->
  <section class="section contact-intro">
    <div class="container">
      <h2 class="contact-heading">Contact</h2>
      <p class="contact-tagline">Thinking about a project?</p>
      <p><strong>WB BUILT PTY LTD</strong></p>
      <p>High-End Residential | Multi-Residential | Commercial Construction</p>
      <p>{site.location}</p>
      <p style="margin-top:20px">If you're exploring options or would like us to take a look, we're happy to have an initial, no-obligation conversation.</p>
    </div>
  </section>

  <!-- Let's Chat + Form -->
  <section class="section contact-form-section">
    <div class="container">
      <h2 class="lets-chat-heading">Let's Chat</h2>

      <div class="contact-details">
        <div>
          <p class="detail-label">Phone</p>
          <p><a href={`tel:${site.phone.replaceAll(' ', '')}`}>{site.phone}</a></p>
        </div>
        <div>
          <p class="detail-label">Email</p>
          <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
        </div>
        <div>
          <p class="detail-label">Social Media</p>
          <a href={site.instagram} target="_blank" rel="noreferrer noopener" class="ig-link" aria-label="WB Built on Instagram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </div>

      <form class="form" name="contact" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="contact" />
        <div class="form-row">
          <label>First Name<input class="input" name="firstName" required /></label>
          <label>Last Name<input class="input" name="lastName" /></label>
        </div>
        <label>Email *<input class="input" type="email" name="email" required /></label>
        <label>Mobile<input class="input" name="mobile" placeholder="Add your number" /></label>
        <label>Message<textarea name="message"></textarea></label>

        <fieldset class="project-type">
          <legend>What are you thinking about?</legend>
          <label class="checkbox-label"><input type="checkbox" name="projectType" value="Residential" /> Residential</label>
          <label class="checkbox-label"><input type="checkbox" name="projectType" value="Multi-residential" /> Multi-residential</label>
          <label class="checkbox-label"><input type="checkbox" name="projectType" value="Commercial" /> Commercial</label>
          <label class="checkbox-label"><input type="checkbox" name="projectType" value="General" /> General</label>
        </fieldset>

        <button class="btn btn-send" type="submit">Send</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* Intro section */
  .contact-intro { background: #fff; }
  .contact-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    color: var(--text);
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }
  .contact-tagline {
    color: var(--muted);
    font-size: 1.05rem;
    margin-bottom: 24px;
  }
  .contact-intro p { color: var(--muted); margin-bottom: 8px; }
  .contact-intro p strong { color: var(--text); }

  /* Form section */
  .contact-form-section { background: #808080; }
  .lets-chat-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    color: #000;
    margin: 0 0 36px;
    letter-spacing: 0.02em;
  }

  /* Contact details row */
  .contact-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 40px;
  }
  .detail-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #000;
    margin-bottom: 8px;
  }
  .contact-details p { color: #000; margin: 0; }
  .contact-details a { color: #000; }
  .contact-details a:hover { color: #333; }
  .ig-link { color: #000; display: inline-block; margin-top: 4px; }
  .ig-link:hover { color: #333; }

  /* Form overrides for grey bg */
  .contact-form-section .form { max-width: 520px; }
  .contact-form-section textarea { min-height: 120px; }

  /* Checkboxes */
  .project-type {
    border: none;
    padding: 0;
    margin: 0;
  }
  .project-type legend {
    color: #000;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .checkbox-label {
    display: flex !important;
    align-items: center;
    gap: 10px;
    color: #000 !important;
    font-size: 0.9rem !important;
    margin-bottom: 8px;
    font-weight: 400 !important;
    cursor: pointer;
  }
  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Send button */
  .btn-send {
    width: 100%;
    background: #5d5a51;
    color: #fff;
    border-color: #5d5a51;
    margin-top: 8px;
    padding: 16px;
    font-size: 0.9rem;
  }
  .btn-send:hover {
    background: #3d3a33;
    border-color: #3d3a33;
    color: #fff;
  }

  @media (max-width: 600px) {
    .contact-details { grid-template-columns: 1fr; }
  }
</style>
