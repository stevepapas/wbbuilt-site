---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { images } from '../data/site';

const categories = [
  { title: 'WB BUILT RESIDENTIAL', img: images.residential, alt: 'WB BUILT RESIDENTIAL' },
  { title: 'WB BUILT COMMERCIAL', img: images.commercial, alt: 'WB BUILT COMMERCIAL' },
  { title: 'WB BUILT HOSPITALITY', img: images.hospitality, alt: 'WB BUILT HOSPITALITY' },
  { title: 'WB BUILT MULTI-RES', img: images.multires, alt: 'WB BUILT MULTI-RES' },
];
---
<BaseLayout title="PORTFOLIO | WB Built Melbourne">
  <Hero />

  <section class="section">
    <div class="container">
      <div class="portfolio-grid">
        {categories.map(({ title, img, alt }) => (
          <article class="portfolio-card">
            <img src={img} alt={alt} loading="lazy" />
            <div class="portfolio-label">{title}</div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    max-width: 600px;
    margin: 0 auto;
  }
  .portfolio-card {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
  }
  .portfolio-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
    opacity: 0.75;
  }
  .portfolio-card:hover img { transform: scale(1.03); opacity: 0.65; }
  .portfolio-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    padding: 16px;
  }
  @media (max-width: 480px) {
    .portfolio-grid { grid-template-columns: 1fr; max-width: 320px; }
  }
</style>
