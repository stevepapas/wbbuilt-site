---
import { site } from '../data/site';
import { routePath, withBase } from '../utils/paths';

const nav = [
  { href: '/', label: 'HOME' },
  { href: '/contact', label: 'CONTACT' },
  { href: '/about', label: 'ABOUT' },
  { href: '/portfolio', label: 'PORTFOLIO' },
];

const pathname = routePath(Astro.url.pathname);
---
<header class="site-header">
  <div class="header-left">
    <button class="hamburger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
    <a class="brand" href={withBase('/')}>WBBUILT</a>
  </div>
  <nav class="desktop-nav" aria-label="Main navigation">
    <button class="search-btn" type="button" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
    {nav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
    <a class="talk" href={withBase('/contact')}>LET'S TALK</a>
    <a class="ig" href={site.instagram} target="_blank" rel="noreferrer noopener" aria-label="Instagram">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
    </a>
  </nav>
</header>

<div class="mobile-menu" id="mobile-menu" hidden>
  <div class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Site navigation">
    <button class="mobile-menu-close" type="button" data-close-menu aria-label="Close menu">&#x2715;</button>
    <nav class="mobile-menu-nav" aria-label="Mobile navigation">
      {nav.map((item) => (
        <a href={withBase(item.href)} class={pathname === item.href ? 'active' : ''}>{item.label}</a>
      ))}
      <a href={withBase('/contact')} class={pathname === '/contact' ? 'active' : ''}>LET'S TALK</a>
    </nav>
  </div>
</div>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(16px, 3vw, 48px);
    height: var(--header-h);
    background: #fff;
    border-bottom: 1px solid #e8e8e8;
    color: #111;
  }
  .header-left {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    width: 32px;
    height: 32px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #111;
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  :global(body.menu-open) .hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  :global(body.menu-open) .hamburger span:nth-child(2) { opacity: 0; }
  :global(body.menu-open) .hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .brand {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    color: #111;
    text-decoration: none;
  }
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(12px, 1.8vw, 26px);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: normal;
    color: #111;
  }
  .desktop-nav a { color: #111; text-decoration: none; }
  .desktop-nav a:hover { opacity: 0.65; }
  .talk { text-decoration: underline; }
  .search-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #111;
    display: flex;
    align-items: center;
    padding: 0;
  }
  .ig { display: flex; align-items: center; }

  .mobile-menu[hidden] { display: none; }
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
  }
  .mobile-menu-panel {
    position: absolute;
    inset: 0;
    background: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transform: translateY(-100%);
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: all;
  }
  :global(body.menu-open) .mobile-menu-panel { transform: translateY(0); }
  .mobile-menu-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.6rem;
    line-height: 1;
    color: #111;
    padding: 8px;
  }
  .mobile-menu-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 7vw, 2.6rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .mobile-menu-nav a {
    color: #111;
    text-decoration: none;
  }
  .mobile-menu-nav a.active { color: var(--muted); }
  .mobile-menu-nav a:hover { opacity: 0.6; }

  @media (max-width: 900px) {
    .hamburger { display: flex; }
    .desktop-nav a,
    .desktop-nav .search-btn { display: none; }
    .desktop-nav .talk,
    .desktop-nav .ig { display: none; }
  }
</style>

<script>
  function initMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const toggle = document.querySelector('.hamburger');
    if (!menu || !toggle) return;

    const openMenu = () => {
      menu.hidden = false;
      requestAnimationFrame(() => document.body.classList.add('menu-open'));
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      document.body.classList.remove('menu-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      window.setTimeout(() => {
        if (!document.body.classList.contains('menu-open')) menu.hidden = true;
      }, 380);
    };

    toggle.addEventListener('click', () => {
      document.body.classList.contains('menu-open') ? closeMenu() : openMenu();
    });

    menu.querySelectorAll('[data-close-menu]').forEach((el) => {
      el.addEventListener('click', closeMenu);
    });

    menu.querySelectorAll('.mobile-menu-nav a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.body.classList.contains('menu-open')) closeMenu();
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
