---
import { images, site } from '../data/site';
import { withBase } from '../utils/paths';
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-content">
      <img src={images.logoOutline} alt="WB Built logo" class="footer-logo" loading="lazy" />
      <a class="footer-email" href={`mailto:${site.email}`}>{site.email}</a>
      <a class="footer-ig" href={site.instagram} target="_blank" rel="noreferrer noopener" aria-label="Instagram">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href={withBase('/faq')}>FAQ</a>
        <a href={withBase('/accessibility-statement')}>Accessibility Statement</a>
        <a href={withBase('/privacy-policy')}>Privacy Policy</a>
      </nav>
    </div>

    <button class="back-to-top" type="button" aria-label="Back to top">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <p class="footer-copy">© 2026 FOLLOWTHELEADER</p>
  </div>
</footer>

<style>
  .footer {
    background: #5c574f;
    margin-top: 24px;
  }

  .footer-inner {
    position: relative;
    padding: clamp(64px, 10vw, 96px) 0 clamp(48px, 8vw, 72px);
    min-height: 420px;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 280px;
  }

  .footer-logo {
    width: min(220px, 55vw);
    margin-bottom: 28px;
  }

  .footer-email {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 400;
    text-decoration: none;
    margin-bottom: 20px;
  }

  .footer-email:hover {
    opacity: 0.75;
  }

  .footer-ig {
    display: flex;
    color: #fff;
    margin-bottom: 36px;
  }

  .footer-ig:hover {
    opacity: 0.75;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 14px;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .footer-links a {
    color: #fff;
    text-decoration: none;
  }

  .footer-links a:hover {
    opacity: 0.75;
  }

  .back-to-top {
    position: absolute;
    left: 50%;
    bottom: clamp(72px, 12vw, 96px);
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border: none;
    border-radius: 50%;
    background: #4a4f55;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease, opacity 0.2s ease;
  }

  .back-to-top:hover {
    background: #3d4248;
  }

  .footer-copy {
    position: absolute;
    left: 0;
    bottom: 0;
    margin: 0;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
  }

  @media (max-width: 700px) {
    .footer-inner {
      min-height: 0;
      padding-bottom: 120px;
    }

    .back-to-top {
      bottom: 56px;
    }
  }
</style>

<script>
  function initBackToTop() {
    const button = document.querySelector('.back-to-top');
    if (!button) return;

    button.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  initBackToTop();
  document.addEventListener('astro:page-load', initBackToTop);
</script>
