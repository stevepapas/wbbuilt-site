---
const { src, alt, speed = '0.35', class: className = '' } = Astro.props;
---
<div class:list={['parallax', className]} data-parallax data-parallax-speed={speed}>
  <img src={src} alt={alt} loading="lazy" />
</div>

<style>
  .parallax {
    overflow: hidden;
    position: relative;
    width: 100%;
    height: 100%;
  }
  .parallax img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .parallax img {
      height: 100%;
      transform: none !important;
    }
  }
</style>
